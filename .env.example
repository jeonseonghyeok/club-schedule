# 배포 서버에서 이 파일을 /opt/club-schedule/.env 로 복사한 뒤 실제 값을 채워 넣는다.
# (이 .env.example 파일 자체는 git에 커밋되어도 되지만, 실제 값이 채워진 .env는 절대 커밋하지 않는다)
#
# Spring Boot는 application.properties의 ${datasource_url} 같은 플레이스홀더와
# KakaoTokenUtil의 @Value("${kakao.rest.key}") 등을 컨테이너 환경변수에서
# 자동으로 읽어온다(대소문자/구두점을 대문자+언더스코어로 바꾼 이름으로 매칭).

DATASOURCE_URL=jdbc:mariadb://scvclub.ddns.net:3306/club_schedule?allowMultiQueries=true
DATASOURCE_USERNAME=
DATASOURCE_PASSWORD=

KAKAO_REST_KEY=
KAKAO_TOKEN_ISSUE_URL=https://kauth.kakao.com/oauth/token
KAKAO_REDIRECT_WHITELIST=/login/kakao/login_callback
KAKAO_CLIENT_SECRET_KEY=

# 운영 환경에서는 비워둬서 /login/test 테스트 로그인을 비활성화한다.
TEST_AUTH_SECRET=
