<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.moyora.clubschedule.mapper.GroupScheduleMapper">

    <!--
        GroupScheduleVo는 모든 필드가 final → Lombok이 전체 필드 순서대로 생성자를 만듦.
        MyBatis는 setter를 쓸 수 없으므로 <constructor> 매핑으로 주입.
        arg 순서는 VO 필드 선언 순서와 정확히 일치해야 한다.
    -->
    <resultMap id="GroupScheduleVoMap" type="com.moyora.clubschedule.vo.GroupScheduleVo">
        <constructor>
            <idArg column="schedule_id"    javaType="java.lang.Long"/>
            <arg   column="group_id"       javaType="java.lang.Long"/>
            <arg   column="title"          javaType="java.lang.String"/>
            <arg   column="content"        javaType="java.lang.String"/>
            <arg   column="location_name"  javaType="java.lang.String"/>
            <arg   column="latitude"       javaType="java.math.BigDecimal"/>
            <arg   column="longitude"      javaType="java.math.BigDecimal"/>
            <arg   column="start_at"       javaType="java.time.LocalDateTime"/>
            <arg   column="end_at"         javaType="java.time.LocalDateTime"/>
            <arg   column="max_attendance" javaType="_int"/>
            <arg   column="status"         javaType="com.moyora.clubschedule.vo.GroupScheduleVo$ScheduleStatus"/>
            <arg   column="created_by"     javaType="java.lang.Long"/>
            <arg   column="approved_by"    javaType="java.lang.Long"/>
            <arg   column="created_at"     javaType="java.time.LocalDateTime"/>
            <arg   column="updated_at"     javaType="java.time.LocalDateTime"/>
            <arg   column="is_completed"   javaType="_boolean"/>
            <arg   column="completed_at"   javaType="java.time.LocalDateTime"/>
        </constructor>
    </resultMap>

    <select id="selectByGroupId" resultMap="GroupScheduleVoMap">
        SELECT
            schedule_id, group_id, title, content,
            location_name, latitude, longitude,
            start_at, end_at, max_attendance,
            status, created_by, approved_by,
            created_at, updated_at, is_completed, completed_at
        FROM group_schedule
        WHERE group_id = #{groupId}
        ORDER BY start_at ASC
    </select>

    <select id="selectByScheduleId" resultMap="GroupScheduleVoMap">
        SELECT
            schedule_id, group_id, title, content,
            location_name, latitude, longitude,
            start_at, end_at, max_attendance,
            status, created_by, approved_by,
            created_at, updated_at, is_completed, completed_at
        FROM group_schedule
        WHERE schedule_id = #{scheduleId}
    </select>

    <select id="countByGroupId" resultType="int">
        SELECT COUNT(*) FROM group_schedule WHERE group_id = #{groupId}
    </select>

    <update id="updateScheduleStatus">
        UPDATE group_schedule
        SET status      = #{status},
            approved_by = #{approvedBy}
        WHERE schedule_id = #{scheduleId}
    </update>

    <insert id="insertSchedule" parameterType="com.moyora.clubschedule.dto.GroupScheduleCreateDto">
        <selectKey keyProperty="scheduleId" resultType="long" order="AFTER">
            SELECT LAST_INSERT_ID()
        </selectKey>
        INSERT INTO group_schedule
            (group_id, title, content, location_name, latitude, longitude,
             start_at, end_at, max_attendance, status, created_by)
        VALUES
            (#{groupId}, #{title}, #{content}, #{locationName}, #{latitude}, #{longitude},
             #{startAt}, #{endAt}, #{maxAttendance}, #{status}, #{createdBy})
    </insert>

</mapper>
